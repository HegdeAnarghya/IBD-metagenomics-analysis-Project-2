# ── Raw sequencing data ──────────────────────────────────────
*.fastq
*.fastq.gz
*.fq
*.fq.gz
*.bam
*.sam
*.cram

# ── HMP2 data files ──────────────────────────────────────────
data/
humann_output/
metaphlan_output/
*.tsv.gz
*.biom

# Keep small processed results if committed directly
!results/*.tsv
!results/*.csv

# ── Large intermediate files ─────────────────────────────────
*.bt2
*.bt2l
*.bowtie2
*.log
*.tmp
temp/
tmp/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/

# ── Jupyter ──────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Conda / virtual environments ─────────────────────────────
.env
*.env
venv/
env/
.conda/

# ── OS / Editor ──────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo
*~

# ── Output figures (remove the # below to exclude figures too)
# figures/
~$*
